{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "declaration": false,
    "incremental": true,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    },
    "resolveJsonModule": true,
    "target": "es2022",
    "types": ["node"]
  },
  "include": [
    ".next/types/**/*.ts",
    ".source/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mdx",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
