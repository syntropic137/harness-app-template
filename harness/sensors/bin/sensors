#!/usr/bin/env bash
# harness/sensors/bin/sensors - TypeScript adapter pair + baseline gate.
#
# Wraps `npx dependency-cruiser` with the workspace-scoped config at the
# repo root, runs the ts-morph Abstractness adapter, and pipes through
# aggregate.mjs (de-dup + scope-filter + per-folder/per-module Martin
# Ca/Ce/I/A/D). Adds a `gate` subcommand (bead create-harness-app-n48.4)
# that enforces a baseline-snapshot fitness floor on every pre-push.
set -euo pipefail

# v8's default old-space limit on CI runners with node 22 lands near 2 GB
# (smaller than node 20's ~4 GB), which is not enough headroom for
# dependency-cruiser's resolver to walk this template's fumadocs / shiki
# / react transitive graph at workspace scope — npx dep-cruiser hits
# FATAL ERROR: Reached heap limit. Pin a 4 GB ceiling here so every node
# child the gate spawns runs with a deterministic, large-enough heap
# regardless of the runner's node-version defaults. Skip when the caller
# already pinned the heap (testing or a constrained operator override).
if [[ "${NODE_OPTIONS:-}" != *"max-old-space-size"* ]]; then
  export NODE_OPTIONS="--max-old-space-size=4096 ${NODE_OPTIONS:-}"
fi

HERE="$(cd "$(dirname "$0")/.." && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"
DEPCRUISER_VERSION="17.4.0"

usage() {
  cat <<'EOF'
harness sensors - workspace architecture-quality metrics

Subcommands:
  report [--format json|md]   Run dependency-cruiser against ws_apps & ws_packages
                              and print Martin Ca/Ce/I/A/D per folder & per module.
  fitness [--quick] [--format text|json|summary]
                              Read-only architectural-health report for coding
                              agents: prints current value + ratchet floor +
                              headroom + PASS/AT-RISK/FAIL per fitness
                              dimension and overall. Reuses gate.mjs and
                              baseline.json; never mutates the floor. Default
                              runs the full pipeline (slow ~108s). --quick
                              renders a floor-only view from baseline.json
                              without re-running sensors (fast; used by the
                              pre-commit one-liner).
  gate [--update-baseline]    Enforce the baseline-snapshot fitness floor at
                              harness/sensors/baseline.json and the governance
                              TOML policy at harness/.harness/governance.toml.
                              Add --policy PATH, --readings-from PATH, or
                              --format json for replay and CI envelopes.
                              Wired into lefthook pre-push.
  adapters                    Print adapter precheck and package fanout JSON.
  deadcode                    Knip dead-code adapter — emits an envelope with
                              total_unused, unused_files, unused_exports, and
                              unused_types across ws_apps and ws_packages. Feeds
                              the MT01 unused-export-count ratchet. Soft-skips
                              cleanly when npx is unavailable
                              (ADR-0024-dead-code-ratchet.md).
  sentrux                     Sentrux adapter precheck (manifest envelope).
                              The actual scan runs inside `gate` via
                              harness/sensors/sentrux_scan.mjs and feeds the
                              MT01 / MD01 / ST01 sentrux ratchet metrics
                              (quality_signal, coupling_score, cycle_count,
                              god_file_count, hotspot_count, complex_fn_count,
                              max_depth). Emits a soft-skip JSON envelope
                              when the sentrux binary is absent (ADR-0017).
  grimp                       Optional grimp-instability adapter entrypoint.
                              Emits a soft-skip JSON envelope when grimp is absent.
  --help                      This text.

Notes:
  - report and gate accept --workspace-root PATH and --skip-tier NAME[,NAME].
  - Reads .dependency-cruiser.cjs at the repo root for scope (includeOnly +
    excludePattern). De-dup and workspace-scope filtering happen here, not in
    cruiser.
  - The `gate` subcommand is the governance-every-run unlock (bead
    create-harness-app-n48.4). The baseline file is committed; the only way
    to lower the floor is `just sensors gate --update-baseline` in a
    deliberate change.
EOF
}

append_skip_tier() {
  local current="$1"
  local addition="$2"
  if [ -z "$current" ]; then
    printf '%s' "$addition"
  else
    printf '%s,%s' "$current" "$addition"
  fi
}

# Build the merged report JSON to a path the caller chooses.
# Sets globals: $cruiser_tmp $abs_tmp $cplx_tmp $report_tmp (caller cleans
# up via trap).
build_report() {
  local out_format="$1"
  local out_path="$2"
  local workspace_root="$3"
  local skip_tier="$4"
  should_skip() {
    local name="$1"
    local base="${name%%@*}"
    local IFS=','
    for skip in $skip_tier; do
      if [ "$skip" = "$name" ] || [ "$skip" = "$base" ]; then
        return 0
      fi
    done
    return 1
  }
  cd "$workspace_root"
  cruiser_tmp="$(mktemp -t harness-sensors-cruiser-XXXXXX.json)"
  abs_tmp="$(mktemp -t harness-sensors-abs-XXXXXX.json)"
  cplx_tmp="$(mktemp -t harness-sensors-cplx-XXXXXX.json)"
  if should_skip "dep-cruiser" || should_skip "dependency-cruiser"; then
    printf '{"summary":{"totalCruised":0,"totalDependenciesCruised":0},"modules":[],"folders":[]}\n' > "$cruiser_tmp"
  else
    if ! command -v npx >/dev/null 2>&1; then
      echo "error: npx not found - install Node.js to run the TS adapter" >&2
      return 2
    fi
    npx --yes "dependency-cruiser@${DEPCRUISER_VERSION}" \
      --metrics --output-type json \
      'ws_apps/**/*.{ts,tsx,js,jsx,mjs,cjs}' \
      'ws_packages/**/*.{ts,tsx,js,jsx,mjs,cjs}' \
      > "$cruiser_tmp"
  fi
  # ts-morph adapters - both take raw cruiser JSON, extract workspace
  # .ts/.tsx sources, and emit per-source readings. Abstractness counts
  # abstract vs concrete declarations; complexity walks function-shaped
  # AST nodes for per-function cyclomatic + cognitive metrics (bead
  # create-harness-app-n48.5).
  if should_skip "ts-morph-abstractness" || should_skip "ts-morph"; then
    printf '{"tool":"ts-morph","available":false,"readings":[],"skipped":true}\n' > "$abs_tmp"
  else
    node "$HERE/abstractness.mjs" < "$cruiser_tmp" > "$abs_tmp"
  fi
  if should_skip "ts-morph-complexity" || should_skip "ts-morph"; then
    printf '{"tool":"ts-morph-complexity","available":false,"readings":[],"skipped":true}\n' > "$cplx_tmp"
  else
    node "$HERE/complexity.mjs" < "$cruiser_tmp" > "$cplx_tmp"
  fi
  # APSS topology adapter (bead n48.3 / ADR-0017): reads .topology/metrics/
  # if present. Closed-loop mode (default): invoke the APSS code-topology
  # producer first so the gate consumes fresh data every cycle. The
  # adapter degrades gracefully when no APSS binary is installed —
  # emits `{available: false, readings: []}` which aggregate.mjs treats
  # as absent. Opt out via APSS_SENSORS_PRODUCE=0 for replay scenarios
  # that need to read a frozen .topology/ snapshot.
  apss_tmp="$(mktemp -t harness-sensors-apss-XXXXXX.json)"
  if should_skip "apss-topology"; then
    printf '{"tool":"apss-topology","available":false,"readings":[],"skipped":true}\n' > "$apss_tmp"
  else
    apss_produce_flag="--produce"
    if [ "${APSS_SENSORS_PRODUCE:-1}" = "0" ]; then
      apss_produce_flag="--no-produce"
    fi
    node "$HERE/apss_topology.mjs" --root="$workspace_root" "$apss_produce_flag" > "$apss_tmp"
  fi
  if [ "$out_path" = "-" ]; then
    node "$HERE/aggregate.mjs" "--format=$out_format" "--abstractness=$abs_tmp" "--complexity=$cplx_tmp" "--apss=$apss_tmp" < "$cruiser_tmp"
  else
    node "$HERE/aggregate.mjs" "--format=$out_format" "--abstractness=$abs_tmp" "--complexity=$cplx_tmp" "--apss=$apss_tmp" < "$cruiser_tmp" > "$out_path"
  fi
}

case "${1:-}" in
  ""|--help|-h|help)
    usage
    ;;
  report)
    shift
    fmt="json"
    workspace_root="$REPO_ROOT"
    skip_tier=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --format)
          fmt="${2:-json}"
          shift 2 || true
          ;;
        --format=*)
          fmt="${1#--format=}"
          shift
          ;;
        --md)
          fmt="md"
          shift
          ;;
        --json)
          fmt="json"
          shift
          ;;
        --workspace-root)
          workspace_root="${2:-$workspace_root}"
          shift 2 || true
          ;;
        --workspace-root=*)
          workspace_root="${1#--workspace-root=}"
          shift
          ;;
        --skip-tier)
          skip_tier="$(append_skip_tier "$skip_tier" "${2:-}")"
          shift 2 || true
          ;;
        --skip-tier=*)
          skip_tier="$(append_skip_tier "$skip_tier" "${1#--skip-tier=}")"
          shift
          ;;
        *)
          echo "error: unknown report flag: $1" >&2
          exit 2
          ;;
      esac
    done
    workspace_root="$(cd "$workspace_root" && pwd)"
    cruiser_tmp=""
    abs_tmp=""
    cplx_tmp=""
    apss_tmp=""
    trap 'rm -f "$cruiser_tmp" "$abs_tmp" "$cplx_tmp" "$apss_tmp"' EXIT
    build_report "$fmt" "-" "$workspace_root" "$skip_tier"
    ;;
  gate)
    shift
    gate_args=()
    readings_from=""
    workspace_root="$REPO_ROOT"
    skip_tier=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --update-baseline)
          gate_args+=("--update-baseline")
          shift
          ;;
        --policy)
          gate_args+=("--policy=${2:-}")
          shift 2 || true
          ;;
        --policy=*)
          gate_args+=("$1")
          shift
          ;;
        --readings-from)
          readings_from="${2:-}"
          gate_args+=("--readings-from=$readings_from")
          shift 2 || true
          ;;
        --readings-from=*)
          readings_from="${1#--readings-from=}"
          gate_args+=("$1")
          shift
          ;;
        --workspace-root)
          workspace_root="${2:-$workspace_root}"
          shift 2 || true
          ;;
        --workspace-root=*)
          workspace_root="${1#--workspace-root=}"
          shift
          ;;
        --skip-tier)
          skip_tier="$(append_skip_tier "$skip_tier" "${2:-}")"
          shift 2 || true
          ;;
        --skip-tier=*)
          skip_tier="$(append_skip_tier "$skip_tier" "${1#--skip-tier=}")"
          shift
          ;;
        --format)
          gate_args+=("--format=${2:-text}")
          shift 2 || true
          ;;
        --format=*)
          gate_args+=("$1")
          shift
          ;;
        --json)
          gate_args+=("--format=json")
          shift
          ;;
        --text)
          gate_args+=("--format=text")
          shift
          ;;
        --baseline=*)
          gate_args+=("$1")
          shift
          ;;
        --baseline)
          gate_args+=("--baseline=${2:-}")
          shift 2 || true
          ;;
        --no-ratchet)
          gate_args+=("--no-ratchet")
          shift
          ;;
        --ratchet)
          gate_args+=("--ratchet")
          shift
          ;;
        --ratchet=*)
          gate_args+=("$1")
          shift
          ;;
        --first-run-mode=*)
          gate_args+=("$1")
          shift
          ;;
        *)
          echo "error: unknown gate flag: $1" >&2
          exit 2
          ;;
      esac
    done
    workspace_root="$(cd "$workspace_root" && pwd)"
    cruiser_tmp=""
    abs_tmp=""
    cplx_tmp=""
    apss_tmp=""
    sec_tmp=""
    lic_tmp=""
    sentrux_tmp=""
    deadcode_tmp=""
    report_tmp="$(mktemp -t harness-sensors-report-XXXXXX.json)"
    trap 'rm -f "$cruiser_tmp" "$abs_tmp" "$cplx_tmp" "$apss_tmp" "$sec_tmp" "$lic_tmp" "$sentrux_tmp" "$deadcode_tmp" "$report_tmp"' EXIT
    if [ -z "$readings_from" ]; then
      build_report "json" "$report_tmp" "$workspace_root" "$skip_tier"
    else
      printf '{}\n' > "$report_tmp"
    fi
    # SC01 Security adapter (bead create-harness-app-2zz.2). Runs UBS over a
    # stable, template-owned set of source paths. Soft-skips when ubs is
    # absent; downstream gate.mjs reports SC01 as no-reading rather than
    # zero so a missing scanner does not silently pass.
    if [ -z "$readings_from" ] && command -v ubs >/dev/null 2>&1; then
      sec_tmp="$(mktemp -t harness-sensors-security-XXXXXX.json)"
      ubs --quiet --report-json="$sec_tmp" \
        --files="scripts/lib/git.ts,scripts/lib/fs.ts,scripts/lib/slots.ts,harness/sensors/aggregate.mjs,harness/sensors/gate.mjs,harness/sensors/abstractness.mjs,harness/sensors/complexity.mjs,harness/sensors/cx_gate.mjs,harness/sensors/apss_topology.mjs,harness/sensors/license_scan.mjs,harness/perf/gate.mjs,harness/perf/bench.sh,harness/sensors/bin/sensors" \
        >/dev/null 2>/dev/null || true
      if [ -s "$sec_tmp" ]; then
        gate_args+=("--security=$sec_tmp")
      fi
    fi
    # LG01 Legality adapter (bead create-harness-app-2zz.3). Walks every
    # node_modules root that exists on disk and counts packages whose
    # declared license is missing or outside the OSI-permissive allowlist.
    # Soft-skips cleanly when no node_modules tree is present (license_scan
    # emits {available: false} and gate.mjs treats LG01 as no-reading).
    if [ -z "$readings_from" ]; then
      lic_tmp="$(mktemp -t harness-sensors-licenses-XXXXXX.json)"
      node "$HERE/license_scan.mjs" > "$lic_tmp" 2>/dev/null || true
      if [ -s "$lic_tmp" ]; then
        gate_args+=("--licenses=$lic_tmp")
      fi
    fi
    # Sentrux adapter (ADR-0017 + ADR-0006): the 2nd architectural lens
    # alongside APSS topology. Runs the sentrux binary scan over the
    # workspace, parses .sentrux/baseline.json, and emits an envelope
    # the gate reads via --sentrux=<path>. Soft-skips cleanly when
    # sentrux is not on PATH (envelope sets available=false; gate.mjs
    # treats every sentrux metric as no-reading rather than a false
    # zero — mirrors the SC01/LG01 wiring above). Skipped when the
    # caller asked to skip sentrux via --skip-tier; replay paths
    # (--readings-from) also skip because the gate is replaying
    # canned readings rather than re-scanning the workspace.
    sentrux_skip=0
    case ",${skip_tier}," in
      *,sentrux,*|*,sentrux@optional,*) sentrux_skip=1 ;;
    esac
    if [ -z "$readings_from" ] && [ "$sentrux_skip" -eq 0 ]; then
      sentrux_tmp="$(mktemp -t harness-sensors-sentrux-XXXXXX.json)"
      node "$HERE/sentrux_scan.mjs" --workspace-root="$workspace_root" \
        > "$sentrux_tmp" 2>/dev/null || true
      if [ -s "$sentrux_tmp" ]; then
        gate_args+=("--sentrux=$sentrux_tmp")
      fi
    fi
    # Knip dead-code adapter (ADR-0024-dead-code-ratchet.md). The 3rd
    # composition lens after dep-cruiser/ts-morph and sentrux: catches
    # unused exports, unused files, and unused types across ws_apps and
    # ws_packages. Soft-skips cleanly when npx or the network is
    # unavailable (envelope sets available=false; gate.mjs degrades the
    # MT01 unused-export-count metric to no-reading — same shape as the
    # SC01/LG01/sentrux wiring above). Skipped via --skip-tier=knip,
    # and on replay (--readings-from) because the gate is replaying
    # canned readings rather than re-scanning the workspace.
    deadcode_skip=0
    case ",${skip_tier}," in
      *,knip,*|*,knip@*,*|*,deadcode,*) deadcode_skip=1 ;;
    esac
    if [ -z "$readings_from" ] && [ "$deadcode_skip" -eq 0 ]; then
      deadcode_tmp="$(mktemp -t harness-sensors-deadcode-XXXXXX.json)"
      node "$HERE/deadcode_scan.mjs" --workspace-root="$workspace_root" \
        > "$deadcode_tmp" 2>/dev/null || true
      if [ -s "$deadcode_tmp" ]; then
        gate_args+=("--deadcode=$deadcode_tmp")
      fi
    fi
    node "$HERE/gate.mjs" "${gate_args[@]+"${gate_args[@]}"}" < "$report_tmp"
    ;;
  fitness)
    shift
    # Read-only fitness report (bead create-harness-app-feat-fitness-feedback-report).
    # Reuses the same readings pipeline as `gate` so the report sees the
    # exact values the gate would compare against the floor, but never
    # writes to harness/sensors/baseline.json. `--quick` skips the
    # readings pipeline entirely and renders the floor-only view from
    # baseline.json (used by the pre-commit one-liner).
    fitness_args=()
    quick=0
    workspace_root="$REPO_ROOT"
    skip_tier=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --quick|--floors-only)
          quick=1
          fitness_args+=("--quick")
          shift
          ;;
        --format)
          fitness_args+=("--format=${2:-text}")
          shift 2 || true
          ;;
        --format=*)
          fitness_args+=("$1")
          shift
          ;;
        --json|--summary|--text)
          fitness_args+=("$1")
          shift
          ;;
        --baseline=*|--readings-from=*|--perf-baseline=*|--security=*|--licenses=*|--sentrux=*|--deadcode=*)
          fitness_args+=("$1")
          shift
          ;;
        --baseline|--readings-from|--perf-baseline|--security|--licenses|--sentrux|--deadcode)
          fitness_args+=("$1" "${2:-}")
          shift 2 || true
          ;;
        --workspace-root)
          workspace_root="${2:-$workspace_root}"
          shift 2 || true
          ;;
        --workspace-root=*)
          workspace_root="${1#--workspace-root=}"
          shift
          ;;
        --skip-tier)
          skip_tier="$(append_skip_tier "$skip_tier" "${2:-}")"
          shift 2 || true
          ;;
        --skip-tier=*)
          skip_tier="$(append_skip_tier "$skip_tier" "${1#--skip-tier=}")"
          shift
          ;;
        --help|-h)
          fitness_args+=("$1")
          shift
          ;;
        *)
          echo "error: unknown fitness flag: $1" >&2
          exit 2
          ;;
      esac
    done
    workspace_root="$(cd "$workspace_root" && pwd)"
    if [ "$quick" -eq 1 ]; then
      node "$HERE/fitness_report.mjs" "${fitness_args[@]+"${fitness_args[@]}"}"
    else
      cruiser_tmp=""
      abs_tmp=""
      cplx_tmp=""
      apss_tmp=""
      sec_tmp=""
      lic_tmp=""
      sentrux_tmp=""
      deadcode_tmp=""
      report_tmp="$(mktemp -t harness-sensors-fitness-XXXXXX.json)"
      trap 'rm -f "$cruiser_tmp" "$abs_tmp" "$cplx_tmp" "$apss_tmp" "$sec_tmp" "$lic_tmp" "$sentrux_tmp" "$deadcode_tmp" "$report_tmp"' EXIT
      build_report "json" "$report_tmp" "$workspace_root" "$skip_tier"
      # Mirror the gate's optional adapter wiring so fitness sees the
      # same SC01/LG01/sentrux/perf readings the gate would.
      if command -v ubs >/dev/null 2>&1; then
        sec_tmp="$(mktemp -t harness-sensors-fitness-security-XXXXXX.json)"
        ubs --quiet --report-json="$sec_tmp" \
          --files="scripts/lib/git.ts,scripts/lib/fs.ts,scripts/lib/slots.ts,harness/sensors/aggregate.mjs,harness/sensors/gate.mjs,harness/sensors/abstractness.mjs,harness/sensors/complexity.mjs,harness/sensors/cx_gate.mjs,harness/sensors/apss_topology.mjs,harness/sensors/license_scan.mjs,harness/perf/gate.mjs,harness/perf/bench.sh,harness/sensors/bin/sensors,harness/sensors/fitness_report.mjs" \
          >/dev/null 2>/dev/null || true
        if [ -s "$sec_tmp" ]; then
          fitness_args+=("--security=$sec_tmp")
        fi
      fi
      lic_tmp="$(mktemp -t harness-sensors-fitness-licenses-XXXXXX.json)"
      node "$HERE/license_scan.mjs" > "$lic_tmp" 2>/dev/null || true
      if [ -s "$lic_tmp" ]; then
        fitness_args+=("--licenses=$lic_tmp")
      fi
      sentrux_skip=0
      case ",${skip_tier}," in
        *,sentrux,*|*,sentrux@optional,*) sentrux_skip=1 ;;
      esac
      if [ "$sentrux_skip" -eq 0 ]; then
        sentrux_tmp="$(mktemp -t harness-sensors-fitness-sentrux-XXXXXX.json)"
        node "$HERE/sentrux_scan.mjs" --workspace-root="$workspace_root" \
          > "$sentrux_tmp" 2>/dev/null || true
        if [ -s "$sentrux_tmp" ]; then
          fitness_args+=("--sentrux=$sentrux_tmp")
        fi
      fi
      # Mirror the knip dead-code wiring from the gate path (see above).
      deadcode_skip=0
      case ",${skip_tier}," in
        *,knip,*|*,knip@*,*|*,deadcode,*) deadcode_skip=1 ;;
      esac
      if [ "$deadcode_skip" -eq 0 ]; then
        deadcode_tmp="$(mktemp -t harness-sensors-fitness-deadcode-XXXXXX.json)"
        node "$HERE/deadcode_scan.mjs" --workspace-root="$workspace_root" \
          > "$deadcode_tmp" 2>/dev/null || true
        if [ -s "$deadcode_tmp" ]; then
          fitness_args+=("--deadcode=$deadcode_tmp")
        fi
      fi
      node "$HERE/fitness_report.mjs" "${fitness_args[@]+"${fitness_args[@]}"}" < "$report_tmp"
    fi
    ;;
  adapters)
    shift
    node "$HERE/adapters.mjs" manifest "$@"
    ;;
  sentrux)
    shift
    node "$HERE/adapters.mjs" run-sentrux "$@"
    ;;
  deadcode)
    shift
    workspace_root="$REPO_ROOT"
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --workspace-root)
          workspace_root="${2:-$workspace_root}"
          shift 2 || true
          ;;
        --workspace-root=*)
          workspace_root="${1#--workspace-root=}"
          shift
          ;;
        *)
          echo "error: unknown deadcode flag: $1" >&2
          exit 2
          ;;
      esac
    done
    workspace_root="$(cd "$workspace_root" && pwd)"
    node "$HERE/deadcode_scan.mjs" --workspace-root="$workspace_root"
    ;;
  grimp)
    shift
    node "$HERE/adapters.mjs" run-grimp "$@"
    ;;
  *)
    echo "error: unknown sensors subcommand: $1" >&2
    echo "try: just sensors --help" >&2
    exit 2
    ;;
esac
