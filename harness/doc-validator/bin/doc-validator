#!/usr/bin/env bash
set -euo pipefail

case "${1:---help}" in
  --help|-h|help)
    cat <<'EOF'
harness doc-validator

The doc-validator slot is present as a stub in this template. Replace
harness/doc-validator with the real validator before enforcing doc validation.
EOF
    ;;
  *)
    echo "[stub] harness-doc-validator: no validator implementation is installed in this template." >&2
    exit 0
    ;;
esac
