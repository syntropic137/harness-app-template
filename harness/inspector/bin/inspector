#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$cmd" in
  screenshot-pair|screenshot)
    exec node harness/inspector/screenshot-pair.mjs "$@"
    ;;
  record-flow|record)
    exec node harness/inspector/record-flow.mjs "$@"
    ;;
  keyframe-grid|keyframes)
    exec node harness/inspector/keyframe-grid.mjs "$@"
    ;;
  help|--help|-h)
    cat <<'EOF'
harness inspector

Usage:
  just inspector screenshot-pair --phase=before|after --url=<url> [--isoKey=<key>]
  just inspector record-flow --phase=before|after --url=<url> (--flow=<name> | --flowFile=<path>) [--evidenceMode=<mode>] [--isoKey=<key>]
  just inspector keyframe-grid <input.webm> <output.jpg>

Built-in flows: navigate (generic, any URL), task-crud (example app).
See harness/inspector/README.md for flow-file authoring and evidence modes.
EOF
    ;;
  *)
    echo "error: unknown inspector command: $cmd" >&2
    echo "try: just inspector --help" >&2
    exit 2
    ;;
esac
