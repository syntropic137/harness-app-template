# Scaffolded by create-harness-app. Materialized as `.gitignore` in the target
# project (source filename is `gitignore` with no leading dot, because `npm
# pack` renames any top-level `.gitignore` in a package to `.npmignore`).
# The scaffold manifest maps `gitignore` -> `.gitignore` at scaffold time.
#
# Captured as E-12 in experiments/2026-05-17--e11-e12-ignore-configs/.

# OS / editor noise
.DS_Store
*.swp
*~

# Logs / env / secrets
*.log
.env
.env.local
.env.runtime

# Private keys and certificates — passive safety net so a credential file
# can never be staged by accident. Gitleaks (lefthook pre-commit + CI) is
# the active gate; these patterns are defense in depth. Use *.example
# stand-ins for anything that must be documented in-repo.
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.keystore
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Harness internals
# Top-level consumer-side .harness/ is local-only (per-fork policy / scratch).
# The slot-side governance file at harness/.harness/governance.toml is the
# *committed* eat-own-dogfood seed — un-ignore it explicitly below.
.harness/
!harness/.harness/
!harness/.harness/**
.worktrees/
.sentrux/

# Agent-plugin vendor symlinks are now COMMITTED so they exist the instant
# the repo is cloned (per WS1 fork-readiness spec, dogfood F-001). The
# canonical body lives at AGENTS.md and CLAUDE.md / GEMINI.md / .codex /
# .gemini are committed symlinks pointing at it. `just bootstrap` verifies
# and repairs the symlinks idempotently. Do not re-add ignore entries here.

# Node / TS
node_modules/
# pnpm-lock.yaml is committed — lock files are the reproducibility contract.
# fork-check / scaffolder-fork-check use --no-frozen-lockfile because they
# simulate a post-rename install; every other CI job uses --frozen-lockfile.
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

# Rust
# Cargo.lock is committed for the same reason as pnpm-lock.yaml above.
target/
**/target/
*.rs.bk
Cargo.lock.bak

# Python
# uv.lock is committed — see pnpm-lock.yaml note above.
.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Go
go.sum
.claude/settings.local.json

# bv (beads viewer) local config and caches
.bv/

# Claude Code caches and ephemeral agent state
.claude/worktrees/
.turbo/

# Editor local config
.vscode/

# Test coverage artifacts
.coverage
**/.coverage
