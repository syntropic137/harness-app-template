# Scaffolded by create-harness-app. Materialized as `.gitignore` in the target
# project (source filename is `gitignore` with no leading dot, because `npm
# pack` renames any top-level `.gitignore` in a package to `.npmignore`).
# The scaffold manifest maps `gitignore` -> `.gitignore` at scaffold time.
#
# Captured as E-12 in experiments/2026-05-17--e11-e12-ignore-configs/.

# OS / editor noise
.DS_Store
*.swp
*~

# Logs / env / secrets
*.log
.env
.env.local

# Harness internals
.harness/
.worktrees/
.sentrux/

# Agent-plugin vendor symlinks (generated by `just bootstrap` → `agents-link`).
# Pure regeneration targets pointing at canonical CLAUDE.md / .claude/. Tracking
# them adds no info and leaves a dirty working tree on first scaffold (E-09).
AGENTS.md
GEMINI.md
.codex
.gemini

# Node / TS
node_modules/
pnpm-lock.yaml
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

# Rust
Cargo.lock
target/
**/target/
*.rs.bk
Cargo.lock.bak

# Python
uv.lock
.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Go
go.sum
.claude/settings.local.json
