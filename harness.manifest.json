{
  "$schema": "./harness.schema.json",
  "name": "polyglot-monorepo",
  "version": "0.4.0",
  "standard": "0.2",
  "description": "Polyglot monorepo with the 12-slot tool-belt harness wired in.",
  "slots": {
    "stack-manager": {
      "contract": "stack-manager",
      "plugin": "harness-stack-node",
      "version": "0.2.0-node-interim+rust-stub",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "cli",
        "entrypoint": "harness/stack/bin/stack",
        "commands": ["boot", "stop", "destroy", "inspect", "ports", "doctor"]
      },
      "implementation": "Working Node/TS stack-manager ported from the lab harness/stack implementation; Rust ADR target remains preserved under harness/stack/rust-stub.",
      "decisionAt": "docs/adrs/ADR-0001-stack-manager.md"
    },
    "inspector": {
      "contract": "inspector",
      "plugin": "playwright-node",
      "version": "1.60",
      "required": false,
      "swappable": true,
      "interface": {
        "type": "cli",
        "entrypoint": "harness/inspector/bin/inspector",
        "commands": ["screenshot-pair", "record-flow", "keyframe-grid"]
      },
      "implementation": "Playwright-based browser evidence capture: screenshot pairs, scripted flow recording (built-in flows plus --flowFile), keyframe grids; iso key via the stack-manager slot, ffmpeg resolved from PATH or the Playwright bundle.",
      "decisionAt": "docs/adrs/ADR-0002-inspector.md"
    },
    "hooks": {
      "contract": "hooks",
      "plugin": "lefthook",
      "version": "1.13",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "config",
        "entrypoint": "lefthook.yml",
        "commands": ["pre-commit", "pre-push"]
      },
      "decisionAt": "docs/adrs/ADR-0003-hooks.md"
    },
    "telemetry-sdk": {
      "contract": "telemetry-sdk",
      "plugin": "opentelemetry-multi",
      "version": "1.x",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "library",
        "entrypoint": "ws_apps/*/src/telemetry.*",
        "config": ["OTEL_EXPORTER_OTLP_ENDPOINT", "OTEL_SERVICE_NAME"]
      },
      "decisionAt": "docs/adrs/ADR-0004-telemetry-sdk.md"
    },
    "observability-stack": {
      "contract": "observability-stack",
      "plugin": "otel-victoria",
      "version": "1.x",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "compose",
        "entrypoint": "harness/observability/compose.harness.yml",
        "config": ["harness/observability/otel-collector.yaml"]
      },
      "decisionAt": "docs/adrs/ADR-0005-observability-stack.md"
    },
    "sensors": {
      "contract": "sensors",
      "plugin": "harness-sensors",
      "version": "0.6.2-ts-adapter+abstractness",
      "required": false,
      "swappable": true,
      "interface": {
        "type": "cli",
        "entrypoint": "harness/sensors/bin/sensors",
        "commands": ["report", "gate"]
      },
      "implementation": "TypeScript adapter pair: dependency-cruiser 17.4.0 (Ca/Ce/I) + ts-morph 23.0.0 (Abstractness A), merged by a Node aggregator that emits per-folder and per-module Martin Ca/Ce/I/A/D where D = |A + I - 1|. APS-V1-0001 topology shards are now merged through `apss_topology.mjs` and consumed by the baseline gate as the canonical fitness signal under ADR-0017.",
      "decisionAt": "docs/adrs/ADR-0006-sensors.md"
    },
    "profiling": {
      "contract": "profiling",
      "plugin": "harness-profiling",
      "version": "0.1.0",
      "required": false,
      "swappable": true,
      "interface": {
        "type": "cli",
        "entrypoint": "harness/profiling/bin/profile",
        "commands": ["startup", "api", "ui", "summary", "gate"]
      },
      "implementation": "Harness-native profiling slot: backend API latency p50/p95/p99 + cpu-prof flamegraph path, frontend CDP performance traces + Core Web Vitals + bundle size via Playwright, startup hyperfine bench re-exposed. Advisory by default; per-signal budgets in harness/profiling/budgets.toml opt into hard gating. OTEL-linked: traceparent per request, trace id in the artifact directory name. Deliberately a slot input, not an APSS dimension.",
      "decisionAt": "docs/adrs/ADR-0026-profiling-slot.md"
    },
    "agent-plugins": {
      "contract": "agent-plugins",
      "plugin": "claude-canonical",
      "version": "0.1",
      "required": false,
      "swappable": true,
      "interface": {
        "type": "directory",
        "entrypoint": ".claude",
        "config": ["CLAUDE.md"]
      },
      "decisionAt": "docs/adrs/ADR-0007-agent-plugins.md"
    },
    "task-runner": {
      "contract": "task-runner",
      "plugin": "just",
      "version": "1.x",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "external",
        "entrypoint": "justfile",
        "commands": ["just"]
      },
      "decisionAt": "docs/adrs/ADR-0008-task-runner.md"
    },
    "secret-scanner": {
      "contract": "secret-scanner",
      "plugin": "gitleaks",
      "version": "8.x",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "external",
        "entrypoint": "gitleaks",
        "commands": ["protect"]
      },
      "decisionAt": "docs/adrs/ADR-0009-secret-scanner.md"
    },
    "doc-validator": {
      "contract": "doc-validator",
      "plugin": "harness-doc-validator",
      "version": "0.1-stub",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "cli",
        "entrypoint": "scripts/doc-validator.mjs",
        "commands": ["check"]
      },
      "implementation": "Primary Rust validator is retained in-harness (`harness/doc-validator`). APSS documentation validation (APS-V1-0003 via `apss.mjs`) is wired as an additional gate, not a replacement.",
      "decisionAt": "docs/adrs/ADR-0010-doc-validator.md"
    },
    "versioning": {
      "contract": "versioning",
      "plugin": "harness-versioning+cocogitto",
      "version": "0.1.0",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "cli",
        "entrypoint": "harness/versioning/bin/versioning",
        "commands": ["check"]
      },
      "implementation": "Rust harness-versioning crate ported from the lab; wraps the cocogitto versioning slot with whole-repo checks and a per-package extension point.",
      "decisionAt": "docs/adrs/ADR-0011-versioning.md"
    },
    "formatter": {
      "contract": "formatter",
      "plugin": "biome+ruff",
      "version": "0.1.0",
      "required": true,
      "swappable": true,
      "interface": {
        "type": "config",
        "entrypoint": "lefthook.yml",
        "commands": ["pre-commit.biome-format-lint", "pre-commit.python-ruff-format"]
      },
      "implementation": "Pre-commit auto-format of staged files via lefthook stage_fixed: biome covers JS/TS/JSON/CSS/MD/YAML, ruff covers Python. Hard-enforced because rewrites are whitespace-equivalent.",
      "decisionAt": "docs/adrs/ADR-0021-formatter-slot.md"
    }
  }
}
