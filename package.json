{
  "name": "agentic-harness-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "turbo"
    ]
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "docs:build": "pnpm --filter @harness/docs build",
    "docs:dev": "pnpm --filter @harness/docs dev",
    "test": "bun run scripts/test.ts",
    "test:scripts": "vitest run scripts/tests --coverage",
    "lint": "bun run scripts/lint.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0",
    "@iarna/toml": "^2.2.5",
    "@vitest/coverage-v8": "^2.1.9",
    "lefthook": "^1.13",
    "ts-morph": "23.0.0",
    "turbo": "^2",
    "vitest": "^2.0"
  }
}
